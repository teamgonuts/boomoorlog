# Boomoorlog local credentials — copy to .env (gitignored) and fill in.
# Never commit the .env file.

# Postgres connection string from Supabase: Settings → Database → Connection string → URI.
# Replace [YOUR-PASSWORD] with the DB password you saved when creating the project.
# If your password contains special chars (% @ : / # ? [ ]), URL-encode them in the URL.
SUPABASE_DB_URL=

# Supabase REST API base URL: Settings → API → Project URL.
SUPABASE_URL=

# Publishable (browser-safe) API key: Settings → API → Publishable key (sb_publishable_...).
SUPABASE_PUBLISHABLE_KEY=
